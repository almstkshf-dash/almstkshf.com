    }\n        } catch (err: any) {\n            setError(err.message);\n        }\n    };\n\n    return (\n        <div className=\"p-8\">\n            <h1 className=\"text-2xl mb-4\">API Proxy Test</h1>\n            <div className=\"flex gap-4 mb-4\">\n                <button \n                    onClick={() => runTest('https://feeds.bbci.co.uk/news/world/rss.xml')}\n                    className=\"bg-primary text-white px-4 py-2 rounded\"\n                >\n                    Test BBC\n                </button>\n                <button \n                    onClick={() => runTest('https://aawsat.com/feed')}\n                    className=\"bg-blue-600 text-white px-4 py-2 rounded\"\n                >\n                    Test Asharq Al-Awsat\n                </button>\n            </div>\n            {error && <p className=\"text-red-500 mt-4\">Error: {error}</p>}\n            {result && <pre className=\"mt-4 p-4 bg-muted overflow-auto max-h-96\">{JSON.stringify(result, null, 2)}</pre>}\n            \n            <div className=\"mt-12\">\n                <h2 className=\"text-xl mb-4 font-bold text-primary\">RssFeeder Component Test</h2>\n                <div className=\"max-w-md border p-4 rounded-xl shadow-lg bg-card\">\n                    <RssFeeder \n                        initialFeedUrl=\"https://aawsat.com/feed\"\n                        initialSourceName=\"asharq_al_awsat\"\n                    />\n                </div>\n            </div>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ceo\\OneDrive\\Desktop\\projects\\almstkshf.com\\almstkshf.com\\src\\app\\actions\\resolveGeminiKey.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\ceo\\OneDrive\\Desktop\\projects\\almstkshf.com\\almstkshf.com\\src\\app\\actions\\stripe.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fa